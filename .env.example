# ===========================================
# Pushboy Configuration
# ===========================================
# Copy this file to .env and fill in your values.
# Keep real APNS/FCM credentials outside git.

# Server
SERVER_PORT=:8080

# ===========================================
# Worker Pool Configuration
# ===========================================
# Tune these for your throughput requirements
# Default capacity: WORKER_COUNT x SENDER_COUNT concurrent requests

# Number of worker goroutines (default: 10)
WORKER_COUNT=10

# Number of sender goroutines per worker (default: 200)
SENDER_COUNT=200

# Size of the job queue buffer (default: 1000)
JOB_QUEUE_SIZE=1000

# Number of tokens to fetch per batch from DB (default: 5000)
# Higher values reduce DB round trips but use more memory
BATCH_SIZE=5000

# Number of retries available to notification outcome retry paths
MAX_RETRY_NOTIFICATION=3

# ===========================================
# Database Configuration
# ===========================================

# Runtime database driver. The current server startup supports Postgres.
DATABASE_DRIVER=postgres

# PostgreSQL connection string. The app runs migrations from db/migrations/postgres on startup.
DATABASE_URL=postgres://user:password@localhost:5432/pushboy?sslmode=disable

# ===========================================
# Apple Push Notification Service (APNS)
# ===========================================
# Get these from Apple Developer Console

# Key ID from your .p8 file (e.g., 52Q5U5B8JV)
APNS_KEY_ID=

# Team ID from Apple Developer account
APNS_TEAM_ID=

# Bundle ID of your iOS app (e.g., com.example.app).
# APNS_TOPIC_ID is still accepted as a fallback, but APNS_BUNDLE_ID is preferred.
APNS_BUNDLE_ID=
APNS_TOPIC_ID=

# Path to APNS .p8 key inside the runtime environment
APNS_KEY_PATH=keys/AuthKey_YOUR_KEY_ID.p8

# true for sandbox APNS, false for production APNS
APNS_USE_SANDBOX=false

# ===========================================
# Firebase Cloud Messaging (FCM)
# ===========================================
# Get these from Firebase Console

# Path to service account JSON. project_id is read from this file.
FCM_KEY_PATH=keys/service-account.json

# ===========================================
# Broadcast Topic
# ===========================================
# Users created by the API are automatically subscribed to this topic.
BROADCAST_TOPIC_NAME=broadcast
